<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FREDLoyalty_App.MVVM.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             NavigationPage.HasBackButton="False"
             >
    
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="home"
                     Text="Home"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnBackButtonClicked" />
    </ContentPage.ToolbarItems>

    <!-- Background -->
    <ContentPage.Background>
        <!--<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource PrimarySecondary_90}"        Offset="0.0" />
            <GradientStop Color="{StaticResource PrimarySecondary_20}" Offset="1.0" />
        </LinearGradientBrush>-->
        <SolidColorBrush Color="{StaticResource White}"/>
    </ContentPage.Background>

    <Grid>

        <Image Source="polymathmenugridapp"
                   Aspect="Fill"/>

        <VerticalStackLayout Padding="25" Spacing="17">

            <!-- Header -->
            <Image Source="polymathapplogoedge"
                          Aspect="AspectFit"
                          WidthRequest="180"
                          HeightRequest="180"
                          VerticalOptions="Center"
                          HorizontalOptions="Center"/>
            
            <!-- Header -->
            <Label Text="Welcome"
               FontSize="14"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="{StaticResource Primary}" />

            <Label Text="Login to your LoyaltyAccount"
               FontSize="12"
               HorizontalOptions="Center"
               TextColor="{StaticResource Primary}" />

            <!-- Form -->
            <Frame BackgroundColor="{StaticResource Gray950}"
               CornerRadius="20"
               Padding="20"
               HasShadow="True">

                <VerticalStackLayout Spacing="0">

                    <!-- Email -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Email"
                           FontSize="11"
                           TextColor="{StaticResource Primary}" />

                        <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource PrimarySecondary_30}"
                            StrokeShape="RoundRectangle 15"
                            HeightRequest="50"
                            Padding="10,0">

                            <Entry Text="{Binding Email}"
                               Placeholder="Enter email"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource Gray500}"
                               PlaceholderColor="{StaticResource Gray300}"
                               VerticalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Password"
                           FontSize="11"
                           TextColor="{StaticResource Primary}" />

                        <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource PrimarySecondary_30}"
                            StrokeShape="RoundRectangle 15"
                            HeightRequest="50"
                            Padding="10,0">

                            <Grid ColumnDefinitions="*,Auto">

                                <Entry Grid.Column="0"
                                       Text="{Binding Password}"
                                       Placeholder="Enter password"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource Gray500}"
                                       PlaceholderColor="{StaticResource Gray300}"
                                       VerticalOptions="Center" />

                                <!-- Eye toggle -->
                                <Image Grid.Column="1"
                                       Source="{Binding EyeIcon}"
                                       HeightRequest="22" WidthRequest="22"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordCommand}" />
                                    </Image.GestureRecognizers>
                                </Image>

                            </Grid>
                        </Border>

                        <!-- Remember Me -->
                        <HorizontalStackLayout Spacing="10" Margin="5,10,0,0">

                            <CheckBox IsChecked="{Binding IsRememberMe}" 
                                  Color="{StaticResource Primary}" />

                            <Label Text="Remember Me"
                               VerticalOptions="Center"
                               TextColor="{StaticResource LightText}" />

                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Login Button -->
            <Button Text="LOGIN"
                BackgroundColor="{StaticResource Primary}"
                TextColor="{StaticResource ButtonText}"
                FontAttributes="Bold"
                CornerRadius="25"
                HeightRequest="55"
                Command="{Binding LoginCommand}" />


            <!-- Google Login -->
            <Border StrokeThickness="1"
                BackgroundColor="#FFFFFF"
                StrokeShape="RoundRectangle 25"
                HeightRequest="50"
                Padding="10" IsEnabled="True">

                <Grid ColumnDefinitions="Auto,*"
                  VerticalOptions="Center">

                    <Image Source="google.png"
                       HeightRequest="20"
                       WidthRequest="20"
                       VerticalOptions="Center"/>

                    <Label Text="Continue with Google"
                       Grid.Column="1"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       TextColor="#000000"
                       FontAttributes="Bold"/>
                </Grid>

                <Border.GestureRecognizers>
                    <!-- Changed from Tapped="OnGoogleLoginClicked" to Command binding -->
                    <TapGestureRecognizer Command="{Binding GoogleLoginCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Apple Login (iOS only) -->
            <Border StrokeThickness="1"
                    BackgroundColor="#000000"
                    StrokeShape="RoundRectangle 25"
                    HeightRequest="50"
                    Padding="10">
                <Border.IsVisible>
                    <OnPlatform x:TypeArguments="x:Boolean">
                        <On Platform="iOS" Value="True" />
                        <On Platform="Android" Value="False" />
                    </OnPlatform>
                </Border.IsVisible>

                <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                <Image Source="apple.png"
                    Grid.Column="0"
                    HeightRequest="20"
                    WidthRequest="20"
                    VerticalOptions="Center"
                    Margin="4,0,0,0" />
                    <Label Text="Continue with Apple"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           TextColor="#FFFFFF"
                           FontAttributes="Bold"/>
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AppleLoginCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Register Redirect -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Don't have an account?"
                   TextColor="{StaticResource LightText}" />

                <Label Text="Register"
                       TextColor="{StaticResource Primary}"
                       FontAttributes="Bold">
                        <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
        <!-- ── Busy overlay — dim + blur + spinner ── -->
        <Grid IsVisible="{Binding IsBusy}"
              InputTransparent="False">

            <!-- Semi-transparent dark overlay -->
            <BoxView BackgroundColor="#80000000"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />

            <!-- Spinner card -->
            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Padding="32,28"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="200">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="48"
                                       WidthRequest="48"
                                       HorizontalOptions="Center" />
                    <Label Text="Please wait..."
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource LightText}" />
                </VerticalStackLayout>
            </Border>

        </Grid>

    </Grid>

</ContentPage>