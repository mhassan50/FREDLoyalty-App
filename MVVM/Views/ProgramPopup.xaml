<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FREDLoyalty_App.MVVM.Views.ProgramsPopup"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid>

        <!-- ── Dim overlay ── -->
        <BoxView BackgroundColor="#CC000000"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ── Popup Card ── -->
        <Border StrokeShape="RoundRectangle 28"
                Stroke="#50295F48"
                StrokeThickness="1"
                HorizontalOptions="Fill"
                VerticalOptions="Center"
                Margin="16,60">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource PrimarySecondary_90}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimarySecondary_20}" Offset="0.5" />
                    <GradientStop Color="{StaticResource PrimarySecondary_40}"         Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,12" Radius="40" Opacity="0.6" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- ── Header ── -->
                <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="24,20,24,0">

                    <!-- Gold shimmer bar -->
                    <BoxView HeightRequest="3"
                             CornerRadius="2"
                             Margin="40,0,40,16"
                             Opacity="0.75" Color="{StaticResource Green500}" />

                    <!-- Brand -->
                    <!-- Header -->
                    <Image Source="logopolymathapplandscape"
                          Aspect="AspectFit"
                          WidthRequest="160"
                          HeightRequest="80"
                          VerticalOptions="Center"
                          HorizontalOptions="Center"/>

                    <!-- Title -->
                    <Label Text="Loyalty Programs"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,0,0,4"
                           TextColor="{StaticResource Primary}" />

                    <Label Text="Current active programs you can earn from"
                           FontSize="11"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource LightText}"
                           Opacity="0.6"
                           Margin="0,0,0,14" />

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Opacity="0.2" Color="{StaticResource Secondary}" />

                </VerticalStackLayout>

                <!-- ── List ── -->
                <Grid Grid.Row="1" Padding="16,10,16,0">

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                    <!-- Empty -->
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="10"
                                         Padding="20">
                        <Label Text="☕"
                               FontSize="36"
                               HorizontalOptions="Center" />
                        <Label Text="No active programs found"
                               FontSize="13"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource LightText}"
                               Opacity="0.6" />
                    </VerticalStackLayout>

                    <!-- Programs list -->
                    <CollectionView ItemsSource="{Binding Programs}"
                                    SelectionMode="None"
                                    IsVisible="{Binding HasPrograms}"
                                    MaximumHeightRequest="420">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#20FFFFFF"
                                        Stroke="#30616b46"
                                        StrokeThickness="1"
                                        Padding="16,14"
                                        Margin="0,0,0,10">

                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                                        <!-- Program name -->
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding LoyaltyName}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               LineBreakMode="WordWrap" />

                                        <!-- Active badge -->
                                        <Border Grid.Row="0" Grid.Column="1"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{Binding StatusBgColor}"
                                                StrokeThickness="0"
                                                Padding="8,4"
                                                VerticalOptions="Start">
                                            <Label Text="{Binding StatusLabel}"
                                                   FontSize="9"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="0.5"
                                                   TextColor="{Binding StatusTextColor}" />
                                        </Border>

                                        <!-- Item name -->
                                        <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2"
                                                               Spacing="6" Margin="0,6,0,0">
                                            <Label Text="☕"
                                                   FontSize="12"
                                                   VerticalOptions="Center" />
                                            <Label Text="{Binding ItemName}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource LightText}"
                                                   Opacity="0.85"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="WordWrap" />
                                        </HorizontalStackLayout>

                                        <!-- Buy X Get Y free -->
                                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                                StrokeShape="RoundRectangle 10"
                                                BackgroundColor="#20616b46"
                                                Stroke="#30616b46"
                                                StrokeThickness="1"
                                                Padding="10,6"
                                                Margin="0,8,0,0"
                                                HorizontalOptions="Start">
                                            <Label Text="{Binding DealLabel}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="0.5"
                                                   TextColor="{StaticResource Primary}" />
                                        </Border>

                                        <!-- Dates -->
                                        <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2"
                                                               Spacing="16"
                                                               Margin="0,10,0,0">

                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="START"
                                                       FontSize="8"
                                                       CharacterSpacing="1.5"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Secondary}"
                                                       Opacity="0.7" />
                                                <Label Text="{Binding StartDateStr}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource LightText}" />
                                            </VerticalStackLayout>

                                            <!-- Arrow -->
                                            <Label Text="→"
                                                   FontSize="16"
                                                   TextColor="{StaticResource Secondary}"
                                                   Opacity="0.5"
                                                   VerticalOptions="End"
                                                   Margin="0,0,0,2" />

                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="END"
                                                       FontSize="8"
                                                       CharacterSpacing="1.5"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Secondary}"
                                                       Opacity="0.7" />
                                                <Label Text="{Binding EndDateStr}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource LightText}" />
                                            </VerticalStackLayout>

                                        </HorizontalStackLayout>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>

                <!-- ── Close Button ── -->
                <VerticalStackLayout Grid.Row="2" Padding="24,14,24,24">

                    <BoxView HeightRequest="1" Opacity="0.2"
                             Color="{StaticResource Secondary}"
                             Margin="0,0,0,14" />

                    <Border StrokeShape="RoundRectangle 22"
                            BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            HorizontalOptions="Fill"
                            HeightRequest="48">
                        <Border.Shadow>
                            <Shadow Brush="#295F48" Offset="0,4" Radius="12" Opacity="0.35" />
                        </Border.Shadow>
                        <Label Text="CLOSE"
                               FontAttributes="Bold"
                               FontSize="13"
                               CharacterSpacing="2"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="{StaticResource ButtonText}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseClicked" />
                        </Border.GestureRecognizers>
                    </Border>

                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
