                       FontSize="10" CharacterSpacing="1"
                       HorizontalOptions="Center"
                       TextColor="#CCFFFFFF" />
            </VerticalStackLayout>

        </Grid>-->

        <!-- ── Branch List ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="BranchList"
                                 Padding="16,20,16,36"
                                 Spacing="12" />
        </ScrollView>

    </Grid>
</ContentPage>