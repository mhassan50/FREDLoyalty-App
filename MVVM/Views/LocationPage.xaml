<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:FREDLoyalty_App.MVVM.Views"
             x:Class="FREDLoyalty_App.MVVM.Views.LocationPage"
             Shell.TabBarIsVisible="True"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <SolidColorBrush Color="{StaticResource White}" />
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">




        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 0 — Header (brown gradient)        -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="0">

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource PrimarySecondary_90}"         Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimarySecondary_30}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Padding="16,36,16,20"
                  ColumnDefinitions="Auto,*,Auto">

                <!-- Back Button -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="#20FFFFFF"
                        Stroke="#40295F48"
                        StrokeThickness="1"
                        Padding="10"
                        VerticalOptions="Center">
                    <Image Source="home"
                           HeightRequest="22"
                           WidthRequest="22"
                           VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Title -->
                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center"
                                     Spacing="3">
                    <Label Text="OUR LOCATIONS"
                           FontSize="17"
                           FontAttributes="Bold"
                           CharacterSpacing="2.5"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="COFFEE PROGRAM"
                           FontSize="10"
                           CharacterSpacing="2"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                </VerticalStackLayout>

                <!-- Total Badge -->
                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="#20FFFFFF"
                        Stroke="#40295F48"                        
                        StrokeThickness="1"
                        Padding="12,6"
                        VerticalOptions="Center">
                    <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 12"
                                BackgroundColor="Transparent"
                                StrokeThickness="0"
                                Padding="0"
                                IsVisible="{Binding IsNotLocating}">
                            <Label Text="↻" FontSize="22"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshLocationCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Gold shimmer line at bottom of header -->
            <BoxView HeightRequest="2"
                     VerticalOptions="End"
                     Opacity="0.6">
                <BoxView.Color>
                    <Color>#616b46</Color>
                </BoxView.Color>
            </BoxView>

        </Grid>


        <!-- ── Header ── --><!--
