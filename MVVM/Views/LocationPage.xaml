        <!-- ── Content ── -->
        <Grid Grid.Row="1">

            <Image Source="polymathmenugridapp"
                   Aspect="Fill"
                   Grid.RowSpan="2"/>
            <!-- No branches -->
            <VerticalStackLayout IsVisible="{Binding NoBranches}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <Label Text="📍" FontSize="48"
                       HorizontalOptions="Center" />
                <Label Text="No locations available"
                       FontSize="14" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>

            <!-- Branch cards built in code-behind -->
            <ScrollView IsVisible="{Binding HasBranches}">
                <VerticalStackLayout Padding="16,16,16,36" Spacing="0">

                    <Label Text="Sorted by nearest to you"
                           FontSize="11"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource LightText}"
                           Margin="0,0,0,16" />

                    <!-- Cards injected here by code-behind -->
                    <VerticalStackLayout x:Name="CardsContainer"
                                         Spacing="0" />

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ── Busy overlay — dim + blur + spinner ── -->
        <Grid IsVisible="{Binding IsLocating}"
              InputTransparent="False" Grid.RowSpan="2">

            <!-- Semi-transparent dark overlay -->
            <BoxView BackgroundColor="#80000000"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />

            <!-- Spinner card -->
            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Padding="32,28"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="200">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsLocating}"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="48"
                                       WidthRequest="48"
                                       HorizontalOptions="Center" />
                    <Label Text="Please wait..."
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource LightText}" />
                </VerticalStackLayout>
            </Border>

        </Grid>

    </Grid>
</ContentPage>
