<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FREDLoyalty_App.MVVM.Views.MorePage"
             Shell.TabBarIsVisible="True"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource White}">

    <Grid RowDefinitions="Auto,*">
        <Image Source="polymathmenugridapp"
                   Aspect="Fill"
                   Grid.RowSpan="2"/>
        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 0 — Header                         -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource PrimarySecondary_90}"         Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimarySecondary_20}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Padding="16,36,16,16"
                  ColumnDefinitions="Auto,*,Auto">

                <!-- Back -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="#20FFFFFF"
                        Stroke="#40616b46"
                        StrokeThickness="1"
                        Padding="10"
                        VerticalOptions="Center">
                    <Image Source="home"
                           HeightRequest="22" WidthRequest="22"
                           VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Title -->
                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center"
                                     Spacing="3">
                    <Label Text="MORE OPTIONS"
                           FontSize="17"
                           FontAttributes="Bold"
                           CharacterSpacing="2.5"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="POLYMATH COFFEE"
                           FontSize="10"
                           CharacterSpacing="2"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                </VerticalStackLayout>

                <!-- Page counter badge -->
                <!--<Border Grid.Column="2"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="#25FFFFFF"
                        Stroke="#40295F48"
                        StrokeThickness="1"
                        Padding="12,6"
                        VerticalOptions="Center">
                    <Label Text="{Binding PageIndicator}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                </Border>-->

            </Grid>

            <BoxView HeightRequest="2" VerticalOptions="End" Opacity="0.6" Color="{StaticResource Gray500}"/>

        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,36" Spacing="10">

                <!-- Section: Actions -->
                <Label Text="QUICK ACTIONS"
                       FontSize="11" CharacterSpacing="2"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       Margin="4,0,0,4" />

                <!-- Offers -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="pricetag.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Offers" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="View active loyalty programs"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenOffersCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- History -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="document.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="History" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="View your purchase history"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenHistoryCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Locations -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="map.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Our Locations" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="Find a Polymath Coffee near you"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenMapCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Divider -->
                <Label Text="FEEDBACK"
                       FontSize="11" CharacterSpacing="2"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       Margin="4,8,0,4" />

                <!-- Rate Us -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="rate.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Rate Us" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="Share your experience with us"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RateUsCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Suggestions -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="idea.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Suggestions" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="Share your ideas with us"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SuggestionsCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Divider -->
                <Label Text="ACCOUNT"
                       FontSize="11" CharacterSpacing="2"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       Margin="4,8,0,4" />

                <!-- My Profile -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="user.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="My Profile" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="Edit your profile"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                    </Border.GestureRecognizers>
                </Border>
                
                <!-- Notifications -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Source="notificationcolor.png"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Notifications" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="View your notifications"
                                   FontSize="11" TextColor="{StaticResource LightText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Logout -->
                <Border StrokeShape="RoundRectangle 14"
                        BackgroundColor="#FFF5F5"
                        Stroke="#FFCCCC" StrokeThickness="1"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*">
                        <Image Grid.Column="0" Source="signout"
                               HeightRequest="28" WidthRequest="28"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <Label Grid.Column="1" Text="Sign Out"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#CC0000" VerticalOptions="Center" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>


        <!-- ── Busy overlay — dim + blur + spinner ── -->
        <Grid IsVisible="{Binding IsLoading}"
              InputTransparent="False" Grid.RowSpan="2">

            <!-- Semi-transparent dark overlay -->
            <BoxView BackgroundColor="#80000000"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />

            <!-- Spinner card -->
            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Padding="32,28"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="200">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="48"
                                       WidthRequest="48"
                                       HorizontalOptions="Center" />
                    <Label Text="Please wait..."
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource LightText}" />
                </VerticalStackLayout>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
