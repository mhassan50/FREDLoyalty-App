<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FREDLoyalty_App.MVVM.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource White}">

    <Grid RowDefinitions="Auto,*">
        <Image Source="polymathmenugridapp"
                   Aspect="Fill"
                   
                   Grid.RowSpan="4"/>
        <!-- ═══════════════════════════════════════ -->
        <!-- ROW 0 — Header                         -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource PrimarySecondary_90}"         Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimarySecondary_20}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Padding="16,36,16,16"
                  ColumnDefinitions="Auto,*,Auto">

                <!-- Back -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="#20FFFFFF"
                        Stroke="#40616b46"
                        StrokeThickness="1"
                        Padding="10"
                        VerticalOptions="Center">
                    <Image Source="home"
                           HeightRequest="22" WidthRequest="22"
                           VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Title -->
                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center"
                                     Spacing="3">
                    <Label Text="My Profile"
                           FontSize="17"
                           FontAttributes="Bold"
                           CharacterSpacing="2.5"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="POLYMATH COFFEE"
                           FontSize="10"
                           CharacterSpacing="2"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                </VerticalStackLayout>


            </Grid>

            <BoxView HeightRequest="2" VerticalOptions="End" Opacity="0.6" Color="{StaticResource Gray500}"/>

        </Grid>

        <!-- ── Content ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- ── Profile Picture ── -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,10,0,0">

                    <Grid HorizontalOptions="Center">
                        <!-- Tappable avatar -->
                        <Border StrokeShape="RoundRectangle 60"
                                BackgroundColor="{StaticResource Gray100}"
                                Stroke="{StaticResource Primary}"
                                StrokeThickness="2"
                                HeightRequest="100" WidthRequest="100"
                                HorizontalOptions="Center">

                            <!-- Base64-decoded image from Snap -->
                            <Image Source="{Binding ProfileImageSource}"
                                   Aspect="AspectFill"
                                   HeightRequest="100" WidthRequest="100"
                                   IsVisible="{Binding HasProfilePicture}" />
                        </Border>

                        <!-- Initials fallback -->
                        <Label Text="{Binding Initials}"
                               FontSize="36" FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="{StaticResource Primary}"
                               IsVisible="{Binding HasNoProfilePicture}" />

                        <!-- Camera badge (edit button) -->
                        <Border StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource Primary}"
                                Stroke="{StaticResource White}"
                                StrokeThickness="2"
                                Padding="6"
                                HeightRequest="32" WidthRequest="32"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                Margin="0,0,0,0">
                            <Image Source="camera.png"
                                   HeightRequest="16" WidthRequest="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickProfileImageCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Google badge if Google user -->
                    <!-- <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="#F0F8F5"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="1"
                            Padding="10,4"
                            HorizontalOptions="Center"
                            IsVisible="{Binding IsGoogleUser}">
                        <HorizontalStackLayout Spacing="6">
                            <Image Source="google.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                            <Label Text="Google Account"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border> -->
                                        <!-- Google badge -->
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="#F0F8F5"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="1"
                            Padding="10,4"
                            HorizontalOptions="Center"
                            IsVisible="{Binding IsGoogleUser}">
                        <HorizontalStackLayout Spacing="6">
                            <Image Source="google.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                            <Label Text="Google Account"
                                FontSize="11" FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Apple badge -->
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="#F2F2F2"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="1"
                            Padding="10,4"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowAppleBadge}">
                        <HorizontalStackLayout Spacing="6">
                            <Image Source="apple.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                            <Label Text="Apple Account"
                                FontSize="11" FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>

                <!-- ── Info Fields ── -->
                <Frame BackgroundColor="{StaticResource Gray100}"
                       CornerRadius="16" Padding="16"
                       HasShadow="False" BorderColor="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="14">

                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="FULL NAME" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource White}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">
                                <Entry Text="{Binding FullName}"
                                       Placeholder="Enter full name"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource Black}"
                                       PlaceholderColor="{StaticResource Gray300}"
                                       VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Mobile -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="MOBILE NUMBER" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource Gray200}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">
                                <Label Text="{Binding MobileNo}"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email (read-only) -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="EMAIL" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource Gray200}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">
                                <Label Text="{Binding Email}"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center"
                                       FontSize="14" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Date of Birth -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="DATE OF BIRTH" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource White}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">
                                <DatePicker Date="{Binding DateOfBirth}"
                                            Format="dd MMM yyyy"
                                            TextColor="{StaticResource Black}"
                                            BackgroundColor="Transparent"
                                            VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <!-- ── Save Profile Button ── -->
                <Button Text="SAVE PROFILE"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        HeightRequest="52"
                        Command="{Binding SaveProfileCommand}" />

                <!-- ── Password Section ── -->
                <Label Text="SECURITY"
                       FontSize="11" CharacterSpacing="2"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       Margin="4,8,0,0" />

                <Frame BackgroundColor="{StaticResource Gray100}"
                       CornerRadius="16" Padding="16"
                       HasShadow="False" BorderColor="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="14">

                        <!-- Google user notice -->
                        <Border StrokeShape="RoundRectangle 10"
                                BackgroundColor="#E8F5E9"
                                Stroke="{StaticResource Green100}" StrokeThickness="1"
                                Padding="12,10"
                                IsVisible="{Binding IsGoogleUser}">
                            <Label Text="You signed in with Google. Set a password below to also enable email login or change curent password."
                                   FontSize="12" TextColor="{StaticResource Green500}"
                                   LineBreakMode="WordWrap" />
                        </Border>

                        <!-- Current Password (only for non-Google users) -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="CURRENT PASSWORD" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource White}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">

                                <Grid ColumnDefinitions="*,Auto">

                                    <Entry Grid.Column="0"
                                           Text="{Binding CurrentPassword}"
                                           Placeholder="Enter current password"
                                           IsPassword="{Binding IsPasswordHidden}"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource Gray500}"
                                           PlaceholderColor="{StaticResource Gray300}"
                                           VerticalOptions="Center" />

                                    <!-- Eye toggle -->
                                    <Image Grid.Column="1"
                                           Source="{Binding EyeIcon}"
                                           HeightRequest="22" WidthRequest="22"
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleCurrentPasswordCommand}" />
                                        </Image.GestureRecognizers>
                                    </Image>

                                </Grid>

 
                            </Border>
                        </VerticalStackLayout>

                        <!-- New Password -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="NEW PASSWORD" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource White}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">
                                <Grid ColumnDefinitions="*,Auto">

                                    <Entry Grid.Column="0"
                                           Text="{Binding NewPassword}"
                                           Placeholder="Enter new password"
                                           IsPassword="{Binding IsNewPasswordHidden}"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource Gray500}"
                                           PlaceholderColor="{StaticResource Gray300}"
                                           VerticalOptions="Center" />

                                    <!-- Eye toggle -->
                                    <Image Grid.Column="1"
                                           Source="{Binding NewEyeIcon}"
                                           HeightRequest="22" WidthRequest="22"
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleNewPasswordCommand}" />
                                        </Image.GestureRecognizers>
                                    </Image>

                                </Grid>

    
                            </Border>
                        </VerticalStackLayout>

                        <!-- Confirm New Password -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="CONFIRM NEW PASSWORD" FontSize="10" CharacterSpacing="1.5"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource White}"
                                    StrokeThickness="0" HeightRequest="48" Padding="12,0">
                                <Grid ColumnDefinitions="*,Auto">

                                    <Entry Grid.Column="0"
                                           Text="{Binding ConfirmNewPassword}"
                                           Placeholder="Confirm new password"
                                           IsPassword="{Binding IsConfirmPasswordHidden}"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource Gray500}"
                                           PlaceholderColor="{StaticResource Gray300}"
                                           VerticalOptions="Center" />

                                    <!-- Eye toggle -->
                                    <Image Grid.Column="1"
                                           Source="{Binding ConfirmEyeIcon}"
                                           HeightRequest="22" WidthRequest="22"
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordCommand}" />
                                        </Image.GestureRecognizers>
                                    </Image>

                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Error -->
                        <Label Text="{Binding PasswordError}"
                               FontSize="12" TextColor="Red"
                               IsVisible="{Binding HasPasswordError}" />

                    </VerticalStackLayout>
                </Frame>

                <!-- Save Password Button -->
                <Button Text="UPDATE PASSWORD"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        HeightRequest="52"
                        Margin="0,0,0,30"
                        Command="{Binding UpdatePasswordCommand}" />

                <!-- Delete Account Button -->
                <Button Text="DELETE ACCOUNT"
                        BackgroundColor="Red"
                        TextColor="{StaticResource White}"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        HeightRequest="52"
                        Margin="0,0,0,30"
                        Command="{Binding DeleteAccountCommand}" />
            </VerticalStackLayout>
        </ScrollView>
        <!-- ── Busy overlay — dim + blur + spinner ── -->
        <Grid IsVisible="{Binding IsBusy}"
              InputTransparent="False" Grid.RowSpan="2">

            <!-- Semi-transparent dark overlay -->
            <BoxView BackgroundColor="#80000000"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />
            <!-- ── Busy overlay — dim + blur + spinner ── -->
            <Grid IsVisible="{Binding IsBusy}"
              InputTransparent="False">

                <!-- Semi-transparent dark overlay -->
                <BoxView BackgroundColor="#80000000"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />

                <!-- Spinner card -->
                <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Padding="32,28"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="200">
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="48"
                                       WidthRequest="48"
                                       HorizontalOptions="Center" />
                        <Label Text="Please wait..."
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource LightText}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

        </Grid>
    </Grid>
</ContentPage>
